# =============================
# 🆓 Personal AI Assistant - 100% FREE Configuration
# =============================

# 🆓 REQUIRED: Google Gemini AI API Key (FREE!)
# Get from: https://makersuite.google.com/app/apikey
# FREE Tier: 15 requests/minute, 1M tokens/day - Perfect for personal use!
GOOGLE_API_KEY=your_free_google_api_key_here

# 🆓 OPTIONAL: Email Functionality (FREE with Gmail!)
# For sending emails through the business agent
# Use Gmail App Password: Google Account → Security → App Passwords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# 🆓 OPTIONAL: Weather Data (FREE!)
# Get from: https://openweathermap.org/api
# FREE Tier: 1000 calls/day - More than enough!
WEATHER_API_KEY=your_free_openweather_api_key_here

# 🆓 OPTIONAL: News Search (FREE!)
# Get from: https://newsapi.org/register  
# FREE Tier: 500 requests/day
NEWS_API_KEY=your_free_newsapi_key_here

# ✅ WEB SEARCH: We use FREE alternatives!
# - DuckDuckGo Search (no API key needed)
# - Wikipedia API (free)
# - Google Custom Search (100 searches/day free)
# NO PAID SerpAPI NEEDED!

# 🆓 ACADEMIC RESEARCH: arXiv (FREE!)
# No API key needed for arXiv academic papers
ARXIV_API_KEY=not_required

# =============================
# 🆓 100% FREE Setup Instructions:
# =============================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys above
# 3. At minimum, you need GOOGLE_API_KEY
# 4. Other keys are optional but enable more features